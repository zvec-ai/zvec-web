"},"1049":{"id":"/en/docs/data-operations/query/filter-134","page_id":"/en/docs/data-operations/query/filter","tags":[],"type":"text","url":"/en/docs/data-operations/query/filter#logical-operators","content":"Logical OR"},"1050":{"id":"/en/docs/data-operations/query/filter-135","page_id":"/en/docs/data-operations/query/filter","tags":[],"type":"text","url":"/en/docs/data-operations/query/filter#logical-operators","content":"role = 'admin' or permission = 'write'"},"1051":{"id":"/en/docs/data-operations/query/filter-136","page_id":"/en/docs/data-operations/query/filter","tags":[],"type":"text","url":"/en/docs/data-operations/query/filter#logical-operators","content":"Evaluates to true if at least one condition is true."},"1052":{"id":"/en/docs/data-operations/query/filter-137","page_id":"/en/docs/data-operations/query/filter","tags":[],"type":"text","url":"/en/docs/data-operations/query/filter#logical-operators","content":"className: text-base"},"1053":{"id":"/en/docs/data-operations/query/filter-138","page_id":"/en/docs/data-operations/query/filter","tags":[],"type":"text","url":"/en/docs/data-operations/query/filter#logical-operators","content":"type: info"},"1054":{"id":"/en/docs/data-operations/query/filter-139","page_id":"/en/docs/data-operations/query/filter","tags":[],"type":"text","url":"/en/docs/data-operations/query/filter#logical-operators","content":"Tip: Use parentheses () to group expressions and control evaluation order, e.g., expr1 and (expr2 or expr3)."},"1055":{"id":"/en/docs/data-operations/query/group","page_id":"/en/docs/data-operations/query/group","type":"page","content":"Grouped Query","breadcrumbs":["User Guide","Working with Data","Data Operations","Query"],"tags":[],"url":"/en/docs/data-operations/query/group"},"1056":{"id":"/en/docs/data-operations/query/group-0","page_id":"/en/docs/data-operations/query/group","tags":[],"type":"text","url":"/en/docs/data-operations/query/group","content":"Grouped Query brings the power of SQL-like GROUP BY semantics to vector search. With this feature, you'll be able to group retrieval results by specified scalar fields — such as category — and perform vector similarity searches within each group."},"1057":{"id":"/en/docs/data-operations/query/group-1","page_id":"/en/docs/data-operations/query/group","tags":[],"type":"text","url":"/en/docs/data-operations/query/group","content":"className: text-base"},"1058":{"id":"/en/docs/data-operations/query/group-2","page_id":"/en/docs/data-operations/query/group","tags":[],"type":"text","url":"/en/docs/data-operations/query/group","content":"type: info"},"1059":{"id":"/en/docs/data-operations/query/group-3","page_id":"/en/docs/data-operations/query/group","tags":[],"type":"text","url":"/en/docs/data-operations/query/group","content":"Grouped Query support will be available in an upcoming release."},"1060":{"id":"/en/docs/data-operations/query/hybrid","page_id":"/en/docs/data-operations/query/hybrid","type":"page","content":"Vector + Filter","breadcrumbs":["User Guide","Working with Data","Data Operations","Query"],"tags":[],"url":"/en/docs/data-operations/query/hybrid"},"1061":{"id":"/en/docs/data-operations/query/hybrid-0","page_id":"/en/docs/data-operations/query/hybrid","type":"heading","tags":[],"url":"/en/docs/data-operations/query/hybrid#prerequisites","content":"Prerequisites"},"1062":{"id":"/en/docs/data-operations/query/hybrid-1","page_id":"/en/docs/data-operations/query/hybrid","type":"heading","tags":[],"url":"/en/docs/data-operations/query/hybrid#performing-filtered-vector-search","content":"Performing Filtered Vector Search"},"1063":{"id":"/en/docs/data-operations/query/hybrid-2","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid","content":"You can combine vector search with scalar filters to restrict results to a subset of documents — just like adding a WHERE clause to a similarity search."},"1064":{"id":"/en/docs/data-operations/query/hybrid-3","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid#prerequisites","content":"This guide assumes you:"},"1065":{"id":"/en/docs/data-operations/query/hybrid-4","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid#prerequisites","content":"Have already opened a collection instance."},"1066":{"id":"/en/docs/data-operations/query/hybrid-5","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid#prerequisites","content":"Are familiar with vector querying and conditional filtering."},"1067":{"id":"/en/docs/data-operations/query/hybrid-6","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid#prerequisites","content":"This example collection contains one dense vector field dense_embedding and one scalar field publish_year."},"1068":{"id":"/en/docs/data-operations/query/hybrid-7","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid#performing-filtered-vector-search","content":"To combine vector similarity search with filters, pass both a VectorQuery and a filter expression to the query() method."},"1069":{"id":"/en/docs/data-operations/query/hybrid-8","page_id":"/en/docs/data-operations/query/hybrid","tags":[],"type":"text","url":"/en/docs/data-operations/query/hybrid#performing-filtered-vector-search","content":"This returns the top-10 most similar documents that satisfy publish_year > 1936, sorted by similarity score."},"1070":{"id":"/en/docs/data-operations/query","page_id":"/en/docs/data-operations/query","type":"page","content":"Query","breadcrumbs":["User Guide","Working with Data","Data Operations","Query"],"tags":[],"url":"/en/docs/data-operations/query"},"1071":{"id":"/en/docs/data-operations/query-0","page_id":"/en/docs/data-operations/query",