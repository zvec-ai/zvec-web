cs/collections/create-50","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#3-vectors-embeddings","content":"metric_type:COSINE, L2, or IP (inner product) — Ensure your metric matches how your embeddings were trained!"},"165":{"id":"/en/docs/collections/create-51","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#3-vectors-embeddings","content":"quantize_type (optional):Compress vectors to reduce index size and speed up search (with slight recall trade-off)"},"166":{"id":"/en/docs/collections/create-52","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#step-2-configure-collection-options","content":"The CollectionOption lets you control runtime behavior when creating the collection:"},"167":{"id":"/en/docs/collections/create-53","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#step-2-configure-collection-options","content":"read_only: Opens the collection in read-only mode. Attempts to write will raise an error."},"168":{"id":"/en/docs/collections/create-54","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#step-2-configure-collection-options","content":"className: text-base"},"169":{"id":"/en/docs/collections/create-55","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#step-2-configure-collection-options","content":"type: warn"},"170":{"id":"/en/docs/collections/create-56","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#step-2-configure-collection-options","content":"Note: read_only must be set to False when calling create_and_open(), since creation requires writing files to disk."},"171":{"id":"/en/docs/collections/create-57","page_id":"/en/docs/collections/create","tags":[],"type":"text","url":"/en/docs/collections/create#s